# KG Coach Dashboard — environment variables
# Copy this file to .env and fill in your values.
# The backend reads these at startup via python-dotenv.

# ── LLM Provider (at least one required for Phase 6+) ────────────────────────

# Anthropic Claude (recommended — used for workout structuring & copilot)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional alternative)
OPENAI_API_KEY=sk-...

# ── Observability — LangSmith tracing (optional) ─────────────────────────────
# Enable LangSmith tracing for the generator's LLM structuring calls and the
# Copilot agent runs.  When unset, tracing is silently disabled — no crash.
#
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=kg-coach-dashboard   # optional — groups traces in LangSmith

# ── Backend settings (optional overrides) ─────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000

# ── Frontend settings ─────────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:8000
